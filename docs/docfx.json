{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": ["NetPdf/NetPdf.csproj"]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**"]
      }
    ],
    "resource": [],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "NetPdf",
      "_appTitle": "NetPdf",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/edcsu/netpdf",
        "branch": "main"
      },
      "pdf": false
    }
  }
}
