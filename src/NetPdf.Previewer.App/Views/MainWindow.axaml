<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NetPdf.Previewer.App.ViewModels"
        x:Class="NetPdf.Previewer.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="NetPdf Previewer"
        Width="1000" Height="750">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8">
            <Button Content="−" Command="{Binding ZoomOutCommand}" />
            <TextBlock Text="{Binding ZoomPercent}" VerticalAlignment="Center" MinWidth="44" TextAlignment="Center" />
            <Button Content="+" Command="{Binding ZoomInCommand}" />
            <Button Content="Fit Width" Click="OnFitWidth" />
            <Button Content="Save PDF…" Click="OnSave" IsEnabled="{Binding HasDocument}" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Padding="8,4" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Vertical" Spacing="2">
                <TextBlock Text="{Binding Status}" />
                <TextBlock Text="{Binding ErrorText}" Foreground="Red" TextWrapping="Wrap"
                           IsVisible="{Binding ErrorText, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>
        </Border>

        <ListBox DockPanel.Dock="Left" Width="120" ItemsSource="{Binding Pages}"
                 SelectionChanged="OnThumbnailSelected">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PageImage">
                    <StackPanel Spacing="2" Margin="4">
                        <Image Source="{Binding Thumbnail}" />
                        <TextBlock Text="{Binding PageNumber}" HorizontalAlignment="Center" FontSize="11" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ScrollViewer Name="PageScroller" HorizontalScrollBarVisibility="Auto">
            <ItemsControl Name="PageList" ItemsSource="{Binding Pages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PageImage">
                        <Border Margin="12" BoxShadow="0 2 8 0 #40000000" HorizontalAlignment="Center">
                            <Image Source="{Binding Image}" Stretch="None" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
